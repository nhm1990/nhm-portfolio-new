{
  "name": "nhm-portfolio-monorepo",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter \"./apps/*\" --parallel dev",
    "dev:portfolio": "pnpm --filter @nhm/portfolio dev",
    "dev:ecoscope": "pnpm --filter @nhm/ecoscope dev",
    "build:portfolio": "pnpm --filter @nhm/portfolio build",
    "build:ecoscope": "pnpm --filter @nhm/ecoscope build",
    "build": "pnpm --filter \"./apps/*\" build"
  },
  "devDependencies": {
    "pnpm": "^10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
